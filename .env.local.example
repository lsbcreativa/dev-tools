# ============================================================
# toolboxurl.com — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ------------------------------------------------------------
# CARBON ADS (Recommended for developer-focused sites)
# Apply: https://www.carbonads.net/
# Once approved, you get a "serve" code like CWYD4K3N
# Ads appear on every tool page automatically
# Expected revenue: $1–5 CPM ($100–500/month per 100k visits)
# ------------------------------------------------------------
NEXT_PUBLIC_CARBON_ADS_SERVE=

# ------------------------------------------------------------
# GOOGLE ADSENSE (Alternative to Carbon Ads)
# Apply: https://adsense.google.com
# After approval, create an ad unit and get your publisher ID
# Expected revenue: $0.5–2 CPM for developer traffic
# ------------------------------------------------------------
# NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_ID=XXXXXXXXXX

# ------------------------------------------------------------
# NEWSLETTER / EMAIL CAPTURE
# Mailchimp (free up to 500 contacts): https://mailchimp.com
# ConvertKit (free up to 10k subs): https://convertkit.com
# After setup, paste your hosted form URL below
# Format: https://xxxxx.us1.list-manage.com/subscribe/post?u=xxx&id=xxx
# ------------------------------------------------------------
NEXT_PUBLIC_NEWSLETTER_FORM_URL=
